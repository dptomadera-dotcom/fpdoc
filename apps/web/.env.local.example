# FPdoc — Web (Next.js) — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.

# Supabase (público, seguro en cliente)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"

# URL de la API NestJS
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Base path (solo en GitHub Pages con subdirectorio; en Vercel dejar vacío)
NEXT_PUBLIC_BASE_PATH=""
