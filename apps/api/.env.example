# FPdoc — API (NestJS) — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.

# Base de datos (Supabase / PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Autenticación
JWT_SECRET="cambia-esto-por-un-secreto-de-al-menos-32-caracteres"

# Supabase (server-side)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# CORS
FRONTEND_URL="http://localhost:3000"

# Puerto API
PORT=4000

# ═════════════════════════════════════════════════════════
# INTELIGENCIA ARTIFICIAL
# ═════════════════════════════════════════════════════════
# Proveedor por defecto: anthropic | openai | glm | minimax | local | groq
AI_PROVIDER="anthropic"

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-7"

# OpenAI (GPT) — https://platform.openai.com
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"

# Zhipu AI (GLM) — https://bigmodel.cn
GLM_API_KEY="zhipuai-..."
GLM_MODEL="glm-5.1"

# MiniMax — https://minimax.io
MINIMAX_API_KEY="mm-..."
MINIMAX_MODEL="minimax-m2.7"

# Ollama (self-hosted) — http://localhost:11434
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma:4b"

# Groq — https://console.groq.com
GROQ_API_KEY="gsk_..."
GROQ_MODEL="mixtral-8x7b-32768"
