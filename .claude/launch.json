{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "fpdoc-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--prefix", "apps/web", "next", "dev", "--port", "3000"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "fpdoc-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "apps/web/out", "-p", "3003", "--no-clipboard"],
      "port": 3003
    }
  ]
}
